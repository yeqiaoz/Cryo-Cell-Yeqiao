  const footer = `
    <button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
    <button class="btn btn-primary" id="passSubmit" onclick="submitPasscode()">Unlock</button>`;
  openModal('&#128274; Edit Mode', body, footer);
  window._passCallback = onSuccess;
  setTimeout(() => {
    const inp = document.getElementById('passInput');
    if (inp) {
      inp.focus();
      inp.addEventListener('keydown', e => { if (e.key === 'Enter') submitPasscode(); });
    }
  }, 60);
}

async function submitPasscode() {
  const inp = document.getElementById('passInput');
  const err = document.getElementById('passError');
  const btn = document.getElementById('passSubmit');
  if (!inp) return;
  btn.disabled = true;
  btn.textContent = 'Checking...';
  const ok = await checkPasscode(inp.value);
  if (ok) {
    closeModal();
    if (window._passCallback) window._passCallback();
  } else {
    err.textContent = 'Incorrect passcode.';
    inp.value = '';
    inp.focus();
    btn.disabled = false;
    btn.textContent = 'Unlock';
  }
}

async function setNewPasscode() {
  const current = prompt('Enter current passcode:');
  if (current === null) return;
  const ok = await checkPasscode(current);
  if (!ok) { alert('Incorrect current passcode.'); return; }
  const newPass = prompt('Enter new passcode:');
  if (!newPass) return;
  const confirm = prompt('Confirm new passcode:');
  if (newPass !== confirm) { alert('Passcodes do not match.'); return; }
  const newHash = await sha256(newPass);
  localStorage.setItem(PASS_KEY, newHash);
  alert('Passcode updated successfully.');
}

// ── EDIT MODE ────────────────────────────────────────
function toggleEdit() {
  if (editMode) {
    // Turning off — no passcode needed
    editMode = false;
    document.body.classList.remove('edit');
    const btn = document.getElementById('editBtn');
    btn.classList.remove('on');
    btn.innerHTML = '&#9998; Edit Mode';
    render();
  } else {
    // Turning on — require passcode
    showPasscodeModal(() => {
      editMode = true;
      document.body.classList.add('edit');
      const btn = document.getElementById('editBtn');
      btn.classList.add('on');
      btn.innerHTML = '&#x2715; Exit Edit';
      render();
      toast('Edit mode unlocked');
    });
  }
}

// ── MODAL ────────────────────────────────────────────
function openModal(title, body, footer) {
  document.getElementById('mTitle').textContent = title;
  document.getElementById('mBody').innerHTML = body;
  document.getElementById('mFooter').innerHTML = footer;
  document.getElementById('overlay').classList.add('on');
  setTimeout(() => {
    const el = document.querySelector('#mBody input, #mBody textarea');
    if (el) { el.focus(); if(el.select) el.select(); }
  }, 60);
}
function closeModal() { document.getElementById('overlay').classList.remove('on'); }
function bgClose(e) { if (e.target === document.getElementById('overlay')) closeModal(); }

// ── VIAL MODAL ───────────────────────────────────────
const ROW_LABELS = 'ABCDEFGHI';

function vialClick(boxId, ri, ci) {
  if (!editMode) return;
  const content = (state[boxId].rows[ri] && state[boxId].rows[ri][ci]) || '';
  const pos = ROW_LABELS[ri] + (ci+1);
  const body = `
    <div class="minfo">Box: <span>${boxId}</span> &nbsp;&middot;&nbsp; Position: <span>${pos}</span></div>
    <div class="mfield"><label>Cell line / content</label>
    <input type="text" id="vialVal" value="${content.replace(/"/g,'&quot;')}" placeholder="Enter cell line, or clear to remove"></div>`;
  const footer = (content ? `<button class="btn btn-danger" onclick="removeVial('${boxId}',${ri},${ci})">Remove</button>` : '') +
    `<button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
     <button class="btn btn-primary" onclick="saveVial('${boxId}',${ri},${ci})">Save</button>`;
  openModal(content ? 'Edit vial ' + pos : 'Add vial at ' + pos, body, footer);
  setTimeout(() => {
    const el = document.getElementById('vialVal');
    if (el) el.onkeydown = e => { if(e.key==='Enter') saveVial(boxId,ri,ci); if(e.key==='Escape') closeModal(); };
  }, 70);
}

function saveVial(boxId, ri, ci) {
  const val = document.getElementById('vialVal').value.trim();
  while (state[boxId].rows.length <= ri) state[boxId].rows.push(Array(9).fill(''));
  state[boxId].rows[ri][ci] = val;
  dirty(); closeModal(); render(); updateStats();
}

function removeVial(boxId, ri, ci) {
  state[boxId].rows[ri][ci] = '';
  dirty(); closeModal(); render(); updateStats();
  toast('Vial removed');
}

// ── BOX OPERATIONS ───────────────────────────────────
function boxRenameModal(boxId) {
  const b = state[boxId];
  const body = `
    <div class="mfield"><label>Box ID</label>
    <input type="text" id="newId" value="${boxId}"></div>
    <div class="mfield"><label>Note</label>
    <input type="text" id="newNote" value="${b.note||''}" placeholder="Optional description"></div>
    <div class="mfield"><label>Type</label>
    <select id="newEss">
      <option value="0" ${!b.essential?'selected':''}>Main Tank</option>
      <option value="1" ${b.essential?'selected':''}>Essential Storage</option>
    </select></div>`;
  const footer = `<button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
    <button class="btn btn-primary" onclick="saveBoxMeta('${boxId}')">Save</button>`;
  openModal('Edit box: ' + boxId, body, footer);
}

function saveBoxMeta(oldId) {
  const newId = document.getElementById('newId').value.trim();
  const note = document.getElementById('newNote').value.trim();
  const essential = document.getElementById('newEss').value === '1';
  if (!newId) return;
  if (newId !== oldId) {
    if (state[newId] && !state[newId].deleted) { toast('ID already exists'); return; }
    state[newId] = { ...state[oldId], id:newId, note, essential };
    delete state[oldId];
    rebuildIds();
  } else {
    state[oldId].note = note;
    state[oldId].essential = essential;
  }
  dirty(); closeModal(); render();
  toast('Box updated');
}

function confirmDelete(boxId) {
  const body = `<p style="color:var(--text-dim);font-size:14px;line-height:1.6">Delete <strong style="color:var(--text)">${boxId}</strong> and all its vials?</p>`;
  const footer = `<button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
    <button class="btn btn-danger" onclick="deleteBox('${boxId}')">Delete</button>`;
  openModal('Delete ' + boxId + '?', body, footer);
}

function deleteBox(boxId) {
  state[boxId].deleted = true;
  rebuildIds(); dirty(); closeModal(); render(); updateStats();
  toast(boxId + ' deleted');
}

function addBoxModal() {
  const nums = Object.keys(state).filter(k=>/^Box\d+$/.test(k)).map(k=>parseInt(k.slice(3)));
  const next = nums.length ? Math.max(...nums)+1 : 1;
  const body = `
    <div class="mfield"><label>Box ID</label><input type="text" id="newId" value="Box${next}"></div>
    <div class="mfield"><label>Note</label><input type="text" id="newNote" value="" placeholder="Optional"></div>
    <div class="mfield"><label>Type</label><select id="newEss">
      <option value="0">Main Tank</option><option value="1">Essential Storage</option>
    </select></div>`;
  const footer = `<button class="btn btn-secondary" onclick="closeModal()">Cancel</button>
    <button class="btn btn-success" onclick="addBox()">Add box</button>`;
  openModal('Add new box', body, footer);
}

function addBox() {
  const id = document.getElementById('newId').value.trim();
  const note = document.getElementById('newNote').value.trim();
  const essential = document.getElementById('newEss').value === '1';
  if (!id) return;
  if (state[id] && !state[id].deleted) { toast('ID already exists'); return; }
  state[id] = { id, note, essential, deleted:false, rows:Array.from({length:9},()=>Array(9).fill('')) };
  rebuildIds(); dirty(); closeModal(); render(); updateStats();
  toast(id + ' added');
}

// ── INLINE BOX EDITING ───────────────────────────────
function commitId(input, oldId) {
  const newId = input.value.trim();
  if (!newId || newId === oldId) { input.value = oldId; return; }
  if (state[newId] && !state[newId].deleted) { toast('ID already exists'); input.value = oldId; return; }
  state[newId] = { ...state[oldId], id: newId };
  delete state[oldId];
  rebuildIds(); dirty();
  toast('Renamed to ' + newId);
  render(); updateStats();
}

function commitNote(input, boxId) {
  if (!state[boxId]) return;
  const note = input.value.trim();
  if (note === (state[boxId].note || '')) return;
  state[boxId].note = note;
  dirty();
}

// ── RENDER ───────────────────────────────────────────
function render() {
  const wrap = document.getElementById('boxesWrap');
  wrap.innerHTML = '';
  const q = document.getElementById('searchBox').value.toLowerCase().trim();
  let visible = 0;

  ids.forEach(id => {
    const b = state[id];
    const allV = b.rows.flat().filter(v => v);
    const filled = allV.length;
    const total = b.rows.reduce((s,r) => s+r.length, 0) || 81;
    const pct = Math.round(filled/total*100);

    const matchQ = !q || allV.some(v => v.toLowerCase().includes(q)) || id.toLowerCase().includes(q);
    const matchF = filterMode==='all' || (filterMode==='ess'&&b.essential) || (filterMode==='filled'&&filled>0);
    if (!matchQ || !matchF) return;
    visible++;

    const card = document.createElement('div');
    card.className = 'box-card' + (b.essential?' ess':'');
    card.style.animationDelay = (visible * 0.02) + 's';

    // Header
    const hdr = document.createElement('div');
    hdr.className = 'box-hdr';

    if (editMode) {
      const idInp = document.createElement('input');
      idInp.type = 'text';
      idInp.value = id;
      idInp.className = 'box-id-input';
      idInp.title = 'Edit box ID';
      idInp.addEventListener('blur', () => commitId(idInp, id));
      idInp.addEventListener('keydown', e => {
        if (e.key === 'Enter') idInp.blur();
        if (e.key === 'Escape') { idInp.value = id; idInp.blur(); }
      });
      idInp.addEventListener('click', e => e.stopPropagation());

      const noteInp = document.createElement('input');
      noteInp.type = 'text';
      noteInp.value = b.note || '';
      noteInp.className = 'box-note-input';
      noteInp.placeholder = 'Add note...';
      noteInp.addEventListener('blur', () => commitNote(noteInp, id));
      noteInp.addEventListener('keydown', e => {
        if (e.key === 'Enter') noteInp.blur();
        if (e.key === 'Escape') { noteInp.value = b.note||''; noteInp.blur(); }
      });
      noteInp.addEventListener('click', e => e.stopPropagation());

      const cnt = document.createElement('div');
      cnt.className = 'box-cnt';
      cnt.textContent = filled + '/' + total;

      hdr.appendChild(idInp);
      hdr.appendChild(noteInp);
      hdr.appendChild(cnt);
    } else {
      const tag = document.createElement('div');
      tag.className = 'box-tag';
      tag.textContent = id;

      const name = document.createElement('div');
      name.className = 'box-note-text';
      name.textContent = b.note ? '\uD83D\uDCDD ' + b.note : (b.essential ? '\u2B50 Essential Storage' : 'Main Tank');

      const cnt = document.createElement('div');
      cnt.className = 'box-cnt';
      cnt.textContent = filled + '/' + total;

      hdr.appendChild(tag);
      hdr.appendChild(name);
      hdr.appendChild(cnt);
    }
    card.appendChild(hdr);

    // Fill bar
    const fr = document.createElement('div');
    fr.className = 'fill-row';
    fr.innerHTML = '<span>' + pct + '% filled</span><span>' + filled + ' vials</span>';
    card.appendChild(fr);

    const fb = document.createElement('div');
    fb.className = 'fill-bar';
    fb.innerHTML = '<div class="fill-inner" style="width:' + pct + '%"></div>';
    card.appendChild(fb);

    // Col labels
    const cl = document.createElement('div');
    cl.className = 'col-lbls';
    for (let i=1;i<=9;i++) { const d=document.createElement('div'); d.className='col-lbl'; d.textContent=i; cl.appendChild(d); }
    card.appendChild(cl);

    // Vial grid
    const grid = document.createElement('div');
    grid.className = 'vgrid';
    for (let ri=0; ri<9; ri++) {
      for (let ci=0; ci<9; ci++) {
        const content = (b.rows[ri] && b.rows[ri][ci] || '').trim();
        const vial = document.createElement('div');
        vial.className = 'vial ' + (content ? 'filled' : 'empty');
        if (content) {
          const col = cellColor(content);
          vial.style.background = col || '#1e3a5c';
          vial.style.borderColor = col || '#2a4f7a';
          vial.style.opacity = '0.78';
          const pos = ROW_LABELS[ri] + (ci+1);
          vial.setAttribute('data-tip', pos + ': ' + content);
          if (q && content.toLowerCase().includes(q)) { vial.classList.add('hl'); vial.style.opacity='1'; }
          else if (q) vial.classList.add('dimmed');
        }
        vial.addEventListener('click', () => vialClick(id, ri, ci));
        grid.appendChild(vial);
      }
    }
    card.appendChild(grid);

    // Edit bar
    const eb = document.createElement('div');
    eb.className = 'box-edit-bar';
    const renameBtn = document.createElement('button');
    renameBtn.className = 'ebb';
    renameBtn.textContent = '\u270F\uFE0F More options';
    renameBtn.addEventListener('click', () => boxRenameModal(id));
    const delBtn = document.createElement('button');
    delBtn.className = 'ebb danger';
    delBtn.textContent = '\uD83D\uDDD1 Delete box';
    delBtn.addEventListener('click', () => confirmDelete(id));
    eb.appendChild(renameBtn);
    eb.appendChild(delBtn);
    card.appendChild(eb);

    wrap.appendChild(card);
  });

  // Add box card
  const addCard = document.createElement('div');
  addCard.className = 'add-box';
  addCard.innerHTML = '<span style="font-size:24px">+</span><span>Add new box</span>';
  addCard.addEventListener('click', addBoxModal);
  wrap.appendChild(addCard);

  if (visible === 0 && ids.length > 0) {
    wrap.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text-muted);font-family:JetBrains Mono,monospace"><p>No boxes match your search.</p></div>';
  }
  document.getElementById('resultsBar').innerHTML =
    'Showing <span>' + visible + '</span> of <span>' + ids.length + '</span> boxes' +
    (q ? ' &middot; "<span>' + q + '</span>"' : '');
}

function setFilter(mode, btn) {
  filterMode = mode;
  document.querySelectorAll('.fb').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function doFilter() { render(); }

// ── LEGEND ───────────────────────────────────────────
function buildLegend() {
  const bar = document.getElementById('legendBar');
  while (bar.children.length > 1) bar.removeChild(bar.lastChild);
  const seen = new Set();
  ids.forEach(id => {
    state[id].rows.flat().forEach(v => {
      const p = matchParent(v);
      if (p && CELL_DB[p] && !seen.has(p)) {
        seen.add(p);
        const item = document.createElement('div');
        item.className = 'leg-item';
        item.innerHTML = '<div class="leg-dot" style="background:' + CELL_DB[p].color + '"></div><span class="leg-label">' + CELL_DB[p].label + '</span>';
        bar.appendChild(item);
      }
    });
  });
}

// ── STATS ────────────────────────────────────────────
function updateStats() {
  let vials = 0; const parents = new Set();
  ids.forEach(id => {
    state[id].rows.flat().forEach(v => {
      if (v) { vials++; const p = matchParent(v); if(p) parents.add(p); }
    });
  });
  document.getElementById('sBoxes').textContent = ids.length;
  document.getElementById('sVials').textContent = vials.toLocaleString();
  document.getElementById('sLines').textContent = parents.size;
}

// ── CLASSIFICATION ───────────────────────────────────
function renderClassification() {
  const wrap = document.getElementById('classWrap');
  const groups = {
    'Human T-cell Leukemia / Lymphoma': ['DND41','Jurkat','KOPTK1','CUTLL1','HPBALL','ALL-SIL','TALL-1'],
    'Human B-cell / Mantle Cell Lymphoma': ['Granta519','Rec1','SP49','Mino','JEKO-1','Millipore CCMCL1','primary MCL PBMC','RL-MCL-14'],
    'Human B-cell Leukemia / Other': ['MEC1','PGA1','JVM2','GM12878','NALM16','REH'],
    'Human Multiple Myeloma': ['U266','RPMI 8226','KMS11','MMIS'],
    'Human Breast Cancer': ['MB157','MCF7','HCC1599','MDA-MB-231','MDA-MB-468','SUM149'],
    'Packaging / Tool Lines': ['293T','PlatE'],
    'Mouse B-cell Lines': ['RAG 1-1','38B9','445*3','3-1','5194','A70'],
  };
  Object.entries(groups).forEach(([title, keys]) => {
    const valid = keys.filter(k => CELL_DB[k]);
    if (!valid.length) return;
    const sec = document.createElement('div');
    sec.innerHTML = '<div class="cs-title">' + title + '</div>';
    const grid = document.createElement('div');
    grid.className = 'cs-grid';
    valid.forEach(key => {
      const info = CELL_DB[key];
      const row = document.createElement('div');
      row.className = 'cell-row';
      const sp = info.species==='human'?'human':'mouse';
      const gr = info.growth==='suspension'?'susp':'adh';
      const ds = (info.disease==='normal'||info.disease==='normal/transformed')?'normal':'disease';
      const ln = info.lineage.includes('T-cell')?'tcell':info.lineage.includes('B-cell')||info.lineage.includes('MCL')?'bcell':info.lineage.includes('breast')?'breast':'other';
      row.innerHTML =
        '<div class="cell-swatch" style="background:' + info.color + '"></div>' +
        '<div><div class="cell-name">' + info.label + '</div>' +
        '<div class="cell-desc">' + info.note + '</div>' +
        '<div class="badges">' +
        '<span class="badge ' + sp + '">' + info.species + '</span>' +
        '<span class="badge ' + gr + '">' + info.growth + '</span>' +
        '<span class="badge ' + ds + '">' + info.disease + '</span>' +
        '<span class="badge ' + ln + '">' + info.lineage + '</span>' +
        '</div></div>';
      grid.appendChild(row);
    });
    sec.appendChild(grid);
    wrap.appendChild(sec);
  });
}

// ── TABS ─────────────────────────────────────────────
function switchTab(tab, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
}

// ── TOAST ────────────────────────────────────────────
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.style.opacity = '1';
  clearTimeout(el._t);
  el._t = setTimeout(() => { el.style.opacity = '0'; }, 2200);
}

// ── INIT ─────────────────────────────────────────────
initState();
updateStats();
buildLegend();
render();
renderClassification();
</script>
</body>
</html>
