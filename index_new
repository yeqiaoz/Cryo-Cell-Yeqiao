function matchParent(val) {
  if (!val) return null;
  const v = val.toLowerCase().trim();
  for (const [pat, key] of MATCH_RULES) if (v.includes(pat)) return key;
  return null;
}
function cellColor(val) {
  const k = matchParent(val);
  return (k && CELL_DB[k]) ? CELL_DB[k].color : null;
}

// ── CSV PARSE ────────────────────────────────────────
function parseCSV(raw) {
  return raw.trim().split('\n').map(line => {
    const cols = []; let cur = '', inQ = false;
    for (const c of line) {
      if (c === '"') { inQ = !inQ; }
      else if (c === ',' && !inQ) { cols.push(cur.trim()); cur = ''; }
      else { cur += c; }
    }
    cols.push(cur.trim());
    return cols;
  });
}

function extractBoxes(rows) {
  const boxes = {}, rowAt = {};
  for (let r = 0; r < rows.length; r++) {
    const row = rows[r];
    if (row[9] && /^Box\d+$/.test(row[9]) && !boxes[row[9]]) {
      boxes[row[9]] = { id:row[9], note:row[10]||'', essential:false, rows:[] };
      rowAt[row[9]] = r;
    }
    if (row[11] && row[11].startsWith('Essential Box') && !boxes[row[11]]) {
      boxes[row[11]] = { id:row[11], note:row[12]||'', essential:true, rows:[] };
      rowAt[row[11]] = r;
    }
  }
  const sortFn = (a,b) => parseInt(a.replace(/\D/g,'')) - parseInt(b.replace(/\D/g,''));
  const leftIds = Object.keys(boxes).filter(k => /^Box\d+$/.test(k)).sort(sortFn);
  const essIds  = Object.keys(boxes).filter(k => k.startsWith('Essential')).sort(sortFn);
  leftIds.forEach((id, bi) => {
    const s = rowAt[id];
    const nxt = bi+1 < leftIds.length ? rowAt[leftIds[bi+1]] : rows.length;
    for (let r = s; r < Math.min(s+9, nxt, rows.length); r++) {
      boxes[id].rows.push(Array.from({length:9}, (_,c) => (rows[r][c]||'').trim()));
    }
  });
  essIds.forEach((id, bi) => {
    const s = rowAt[id];
    const nxt = bi+1 < essIds.length ? rowAt[essIds[bi+1]] : rows.length;
    for (let r = s; r < Math.min(s+9, nxt, rows.length); r++) {
      boxes[id].rows.push(Array.from({length:9}, (_,c) => (rows[r][12+c]||'').trim()));
    }
  });
  return boxes;
}

const parsedBoxes = extractBoxes(parseCSV(RAW));

// ── STATE ────────────────────────────────────────────
const SKEY = 'cryo_v2';
let state = {};       // id -> {id, note, essential, rows, deleted}
let ids = [];         // sorted active ids
let pending = 0;
let editMode = false;
let filterMode = 'all';

function initState() {
  state = {};
  Object.entries(parsedBoxes).forEach(([id, b]) => {
    state[id] = { id, note: b.note, essential: b.essential, deleted: false,
                  rows: b.rows.map(r => [...r]) };
  });
  try {
    const saved = JSON.parse(localStorage.getItem(SKEY) || '{}');
    Object.entries(saved).forEach(([id, s]) => {
      if (state[id]) Object.assign(state[id], s);
      else state[id] = s;
    });
  } catch(e) {}
  rebuildIds();
  pending = 0;
  updateChangeBar();
}

function rebuildIds() {
  ids = Object.keys(state)
    .filter(id => !state[id].deleted)
    .sort((a,b) => {
      const ae = a.startsWith('E'), be = b.startsWith('E');
      if (ae && !be) return -1; if (!ae && be) return 1;
      return parseInt(a.replace(/\D/g,'')) - parseInt(b.replace(/\D/g,''));
    });
}

function dirty() { pending++; updateChangeBar(); }

function updateChangeBar() {
  const bar = document.getElementById('changeBar');
  document.getElementById('changeCount').textContent = pending + ' unsaved change' + (pending===1?'':'s');
  bar.classList.toggle('on', pending > 0);
}

function doSave() {
  const diff = {};
  Object.entries(state).forEach(([id, s]) => {
    const orig = parsedBoxes[id];
    if (!orig || s.deleted || s.note !== orig.note ||
        JSON.stringify(s.rows) !== JSON.stringify(orig.rows)) {
      diff[id] = { ...s, rows: s.rows.map(r => [...r]) };
    }
  });
  localStorage.setItem(SKEY, JSON.stringify(diff));
  pending = 0; updateChangeBar();
  toast('Saved to browser storage');
}

function doExport() {
  const lines = [];
  ids.forEach(id => {
    state[id].rows.forEach(row => {
      lines.push(row.map(c => c.includes(',') ? '"'+c+'"' : c).join(','));
    });
    lines.push('');
  });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([lines.join('\n')], {type:'text/csv'}));
  a.download = 'cryo_export.csv'; a.click();
}

function doReset() {
  if (!confirm('Reset ALL changes to original data?')) return;
  localStorage.removeItem(SKEY);
  initState(); render(); updateStats();
  toast('Reset to original');
}

// ── PASSCODE ─────────────────────────────────────────
// To change the passcode: run this in your browser console:
//   setNewPasscode()
// You will be prompted for the current passcode, then a new one.
// The new hash is saved to localStorage and takes effect immediately.

const DEFAULT_HASH = '846182c398460222725ca978b785551e7eda4618044e1758eb1f3603670c5c45';
const PASS_KEY = 'cryo_passcode_hash';

function getHash() {
  return localStorage.getItem(PASS_KEY) || DEFAULT_HASH;
}

async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

async function checkPasscode(input) {
  const h = await sha256(input);
  return h === getHash();
}

