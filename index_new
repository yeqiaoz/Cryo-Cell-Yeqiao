<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cryo Tank Inventory</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#080c14; --surface:#0f1624; --surface2:#161f30; --surface3:#1c2840;
  --border:#1e2d47; --border2:#253552; --accent:#38bdf8; --text:#dde5f0;
  --text-dim:#8da0bb; --text-muted:#4a6080; --essential:#f59e0b; --radius:10px;
  --c0:#38bdf8;--c1:#f472b6;--c2:#a78bfa;--c3:#34d399;--c4:#fb923c;
  --c5:#e879f9;--c6:#facc15;--c7:#f87171;--c8:#4ade80;--c9:#60a5fa;
  --c10:#c084fc;--c11:#fdba74;--c12:#86efac;--c13:#67e8f9;--c14:#fda4af;
  --c15:#d9f99d;--c16:#a5f3fc;--c17:#fbbf24;--c18:#f9a8d4;--c19:#7dd3fc;--c20:#6ee7b7;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(56,189,248,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(56,189,248,.025) 1px,transparent 1px);background-size:32px 32px;pointer-events:none;z-index:0}
.app{position:relative;z-index:1;display:flex;flex-direction:column;min-height:100vh}

/* HEADER */
header{padding:16px 28px;border-bottom:1px solid var(--border);background:rgba(8,12,20,.96);backdrop-filter:blur(10px);position:sticky;top:0;z-index:200;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.logo{display:flex;flex-direction:column;gap:1px;margin-right:auto}
.logo h1{font-family:'JetBrains Mono',monospace;font-size:15px;font-weight:700;color:var(--accent)}
.logo p{font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;letter-spacing:.4px}
.stats{display:flex;gap:20px}
.stat{text-align:center}
.stat-v{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:var(--accent)}
.stat-l{font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:var(--text-muted)}
.edit-toggle{padding:7px 14px;border-radius:6px;border:1px solid var(--border);background:var(--surface2);color:var(--text-dim);font-size:12px;font-family:'JetBrains Mono',monospace;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:6px;white-space:nowrap}
.edit-toggle:hover{border-color:var(--essential);color:var(--essential)}
.edit-toggle.on{background:rgba(245,158,11,.15);border-color:var(--essential);color:var(--essential);font-weight:600}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--border);background:rgba(8,12,20,.9);padding:0 28px;position:sticky;top:57px;z-index:199}
.tab{padding:11px 18px 10px;font-size:13px;font-weight:500;color:var(--text-dim);cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;transition:all .15s;font-family:'DM Sans',sans-serif;margin-bottom:-1px}
.tab:hover{color:var(--text)}
.tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.tab-panel{display:none;flex-direction:column}
.tab-panel.active{display:flex}

/* CHANGE BAR */
.change-bar{display:none;padding:7px 28px;background:rgba(245,158,11,.08);border-bottom:1px solid rgba(245,158,11,.2);font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--essential);align-items:center;gap:10px}
.change-bar.on{display:flex}
.change-bar button{font-size:11px;padding:2px 9px;border-radius:4px;border:1px solid rgba(245,158,11,.4);background:none;color:var(--essential);cursor:pointer;font-family:'JetBrains Mono',monospace}
.change-bar button:hover{background:rgba(245,158,11,.15)}

/* CONTROLS */
.controls{padding:11px 28px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;border-bottom:1px solid var(--border);background:rgba(15,22,36,.7)}
.sw{position:relative;flex:1;min-width:180px;max-width:360px}
.sw svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted)}
input[type=search]{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:8px 11px 8px 32px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;outline:none;transition:border-color .2s}
input[type=search]:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(56,189,248,.1)}
input[type=search]::placeholder{color:var(--text-muted)}
.fg{display:flex;gap:5px;flex-wrap:wrap}
.fb{padding:6px 12px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--text-dim);font-size:12px;font-family:'JetBrains Mono',monospace;cursor:pointer;transition:all .15s;white-space:nowrap}
.fb:hover{border-color:var(--accent);color:var(--accent)}
.fb.active{background:var(--accent);color:var(--bg);border-color:var(--accent);font-weight:600}
.fb.ess.active{background:var(--essential);border-color:var(--essential);color:var(--bg)}
.results-bar{padding:6px 28px;font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text-muted);border-bottom:1px solid var(--border)}
.results-bar span{color:var(--accent)}

/* LEGEND */
.legend-bar{padding:7px 28px;display:flex;gap:10px;flex-wrap:wrap;border-bottom:1px solid var(--border);background:rgba(8,12,20,.7);align-items:center}
.legend-bar-title{font-size:10px;color:var(--text-muted);font-family:'JetBrains Mono',monospace}
.leg-item{display:flex;align-items:center;gap:4px}
.leg-dot{width:8px;height:8px;border-radius:2px}
.leg-label{font-size:10px;color:var(--text-dim);font-family:'JetBrains Mono',monospace;white-space:nowrap}

/* BOX GRID */
.boxes-wrap{padding:18px 28px;display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:14px}

/* BOX CARD */
.box-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:border-color .2s,box-shadow .2s;animation:fadeUp .22s ease both}
.box-card:hover{border-color:var(--border2);box-shadow:0 0 18px rgba(56,189,248,.05)}
.box-card.ess{border-color:rgba(245,158,11,.25)}
.box-card.ess:hover{border-color:rgba(245,158,11,.45)}
.box-card.hidden{display:none}

/* BOX HEADER */
.box-hdr{padding:9px 13px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);background:var(--surface2)}
.box-tag{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;background:rgba(56,189,248,.1);color:var(--accent);white-space:nowrap;flex-shrink:0}
.ess .box-tag{background:rgba(245,158,11,.12);color:var(--essential)}
.box-note-text{font-size:12px;font-weight:500;color:var(--text);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.box-cnt{font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;white-space:nowrap}

/* INLINE EDIT INPUTS */
.box-id-input{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;border:1px dashed rgba(245,158,11,.6);background:rgba(245,158,11,.08);color:var(--essential);width:76px;outline:none;transition:all .15s}
.box-id-input:focus{border-style:solid;border-color:var(--essential);background:rgba(245,158,11,.15);box-shadow:0 0 0 2px rgba(245,158,11,.15)}
.box-note-input{font-size:12px;font-weight:400;color:var(--text-dim);background:transparent;border:1px dashed rgba(56,189,248,.3);border-radius:4px;padding:2px 7px;outline:none;flex:1;font-family:'DM Sans',sans-serif;min-width:0;transition:all .15s}
.box-note-input::placeholder{color:var(--text-muted);font-style:italic;font-size:11px}
.box-note-input:focus{border-style:solid;border-color:var(--accent);background:var(--surface2);color:var(--text)}

/* FILL BAR */
.fill-row{padding:5px 13px 2px;display:flex;justify-content:space-between;font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--text-muted)}
.fill-row span:last-child{color:var(--accent)}
.fill-bar{margin:0 13px 9px;height:2px;background:var(--surface3);border-radius:1px;overflow:hidden}
.fill-inner{height:100%;background:linear-gradient(90deg,#7c3aed,var(--accent));border-radius:1px}

/* COLUMN LABELS */
.col-lbls{padding:0 13px;display:grid;grid-template-columns:repeat(9,1fr);gap:3px}
.col-lbl{text-align:center;font-size:8px;font-family:'JetBrains Mono',monospace;color:var(--text-muted)}

/* VIAL GRID */
.vgrid{padding:3px 13px 12px;display:grid;grid-template-columns:repeat(9,1fr);gap:3px}
.vial{aspect-ratio:1;border-radius:3px;position:relative;border:1px solid transparent;transition:transform .1s}
.vial.empty{background:#0b1220;border-color:#0f1929}
.vial.filled{cursor:pointer}
.vial.filled:hover{transform:scale(1.18);z-index:10}
.vial.dimmed{opacity:.15}
.vial.hl{animation:vpulse 1.8s ease infinite}
.vial[data-tip]:hover::before{content:attr(data-tip);position:absolute;bottom:calc(100% + 7px);left:50%;transform:translateX(-50%);background:#060a12;border:1px solid var(--border2);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:10px;padding:5px 9px;border-radius:5px;white-space:normal;z-index:1000;pointer-events:none;box-shadow:0 4px 14px rgba(0,0,0,.7);max-width:200px;text-align:center;line-height:1.5}

/* EDIT MODE */
body.edit .vial.empty{border-style:dashed;border-color:#1a3050;background:#0c1828;cursor:pointer}
body.edit .vial.empty:hover{border-color:#34d399;background:rgba(52,211,153,.08)}
body.edit .vial.filled:hover{border-color:var(--essential) !important}
.box-edit-bar{display:none;padding:6px 13px 8px;gap:6px;align-items:center;border-top:1px solid var(--border)}
body.edit .box-edit-bar{display:flex}
.ebb{font-size:11px;padding:3px 9px;border-radius:4px;border:1px solid var(--border);background:var(--surface2);color:var(--text-dim);cursor:pointer;font-family:'JetBrains Mono',monospace;transition:all .12s}
.ebb:hover{border-color:var(--accent);color:var(--accent)}
.ebb.danger:hover{border-color:#f87171;color:#f87171}

/* ADD BOX */
.add-box{display:none;background:var(--surface);border:2px dashed var(--border);border-radius:var(--radius);min-height:100px;cursor:pointer;align-items:center;justify-content:center;flex-direction:column;gap:8px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;font-size:13px;transition:all .15s}
body.edit .add-box{display:flex}
.add-box:hover{border-color:#34d399;color:#34d399}

/* MODAL */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.overlay.on{display:flex}
.modal{background:var(--surface);border:1px solid var(--border2);border-radius:12px;width:420px;max-width:95vw;box-shadow:0 24px 60px rgba(0,0,0,.8);animation:mIn .15s ease}
.mhdr{padding:15px 20px 13px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.mhdr h3{font-size:14px;font-weight:600;color:var(--text)}
.mclose{background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:18px;padding:2px 6px;border-radius:4px;transition:color .15s;line-height:1}
.mclose:hover{color:var(--text)}
.mbody{padding:18px 20px}
.mbody label{display:block;font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px}
.mbody input,.mbody select,.mbody textarea{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:9px 12px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color .2s;resize:vertical}
.mbody input:focus,.mbody select:focus{border-color:var(--accent)}
.mbody select option{background:var(--surface)}
.mfield{margin-bottom:14px}
.minfo{font-size:11px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;margin-bottom:14px}
.minfo span{color:var(--accent)}
.mfooter{padding:11px 20px 15px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}
.btn{padding:8px 16px;border-radius:7px;font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border:1px solid transparent;font-family:'DM Sans',sans-serif}
.btn-primary{background:var(--accent);color:var(--bg);border-color:var(--accent)}
.btn-primary:hover{background:#7dd3fc}
.btn-secondary{background:var(--surface2);color:var(--text-dim);border-color:var(--border)}
.btn-secondary:hover{border-color:var(--border2);color:var(--text)}
.btn-danger{background:rgba(248,113,113,.1);color:#f87171;border-color:rgba(248,113,113,.3)}
.btn-danger:hover{background:rgba(248,113,113,.2);border-color:#f87171}
.btn-success{background:rgba(52,211,153,.1);color:#34d399;border-color:rgba(52,211,153,.3)}
.btn-success:hover{background:rgba(52,211,153,.2);border-color:#34d399}

/* CLASSIFICATION */
.class-wrap{padding:20px 28px;display:flex;flex-direction:column;gap:20px}
.cs-title{font-size:11px;text-transform:uppercase;letter-spacing:1.2px;color:var(--text-muted);font-family:'JetBrains Mono',monospace;margin-bottom:10px;padding-bottom:6px;border-bottom:1px solid var(--border)}
.cs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px}
.cell-row{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 14px;display:flex;align-items:flex-start;gap:10px;transition:border-color .15s}
.cell-row:hover{border-color:var(--border2)}
.cell-swatch{width:10px;height:10px;border-radius:2px;flex-shrink:0;margin-top:3px}
.cell-name{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;color:var(--text);margin-bottom:4px}
.cell-desc{font-size:11px;color:var(--text-dim);margin-bottom:5px;font-family:'JetBrains Mono',monospace}
.badges{display:flex;gap:4px;flex-wrap:wrap}
.badge{font-size:10px;padding:1px 6px;border-radius:3px;font-family:'JetBrains Mono',monospace;white-space:nowrap}
.badge.human{background:rgba(56,189,248,.12);color:#7dd3fc}
.badge.mouse{background:rgba(74,222,128,.12);color:#86efac}
.badge.susp{background:rgba(167,139,250,.12);color:#c4b5fd}
.badge.adh{background:rgba(251,146,60,.12);color:#fdba74}
.badge.normal{background:rgba(34,197,94,.12);color:#86efac}
.badge.disease{background:rgba(248,113,113,.12);color:#fca5a5}
.badge.tcell{background:rgba(236,72,153,.12);color:#f9a8d4}
.badge.bcell{background:rgba(99,102,241,.12);color:#a5b4fc}
.badge.breast{background:rgba(251,191,36,.12);color:#fde68a}
.badge.other{background:rgba(100,116,139,.12);color:#94a3b8}

#toast{position:fixed;bottom:24px;right:24px;background:#1c2840;border:1px solid var(--border2);color:var(--text);padding:10px 16px;border-radius:8px;font-size:12px;font-family:'JetBrains Mono',monospace;z-index:2000;opacity:0;transition:opacity .3s;pointer-events:none}

@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes vpulse{0%,100%{box-shadow:0 0 0 0 rgba(56,189,248,.5)}50%{box-shadow:0 0 0 3px rgba(56,189,248,0)}}
@keyframes mIn{from{opacity:0;transform:scale(.95) translateY(8px)}to{opacity:1;transform:none}}
</style>
</head>
<body>
<div class="app">

<header>
  <div class="logo">
    <h1>&#10052; CRYO TANK INVENTORY</h1>
    <p>YEQIAO LAB &middot; LIQUID NITROGEN STORAGE</p>
  </div>
  <div class="stats">
    <div class="stat"><div class="stat-v" id="sBoxes">-</div><div class="stat-l">Boxes</div></div>
    <div class="stat"><div class="stat-v" id="sVials">-</div><div class="stat-l">Vials</div></div>
    <div class="stat"><div class="stat-v" id="sLines">-</div><div class="stat-l">Cell Lines</div></div>
  </div>
  <button class="edit-toggle" id="editBtn" onclick="toggleEdit()">&#9998; Edit Mode</button>
</header>

<div class="change-bar" id="changeBar">
  <span id="changeCount">0 unsaved changes</span>
  <button onclick="doSave()">&#128190; Save</button>
  <button onclick="doExport()">&#8595; Export CSV</button>
  <button onclick="doReset()" style="opacity:.7">&#8617; Reset all</button>
</div>

<div class="tabs">
  <button class="tab active" onclick="switchTab('inv',this)">&#128230; Inventory</button>
  <button class="tab" onclick="switchTab('cls',this)">&#128300; Cell Line Classification</button>
</div>

<!-- INVENTORY TAB -->
<div class="tab-panel active" id="tab-inv">
  <div class="controls">
    <div class="sw">
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="search" id="searchBox" placeholder="Search cell line, construct, clone..." oninput="doFilter()">
    </div>
    <div class="fg">
      <button class="fb active" onclick="setFilter('all',this)">All</button>
      <button class="fb ess" onclick="setFilter('ess',this)">&#11088; Essential</button>
      <button class="fb" onclick="setFilter('filled',this)">Has Cells</button>
    </div>
  </div>
  <div class="legend-bar" id="legendBar"><span class="legend-bar-title">COLOR KEY:</span></div>
  <div class="results-bar" id="resultsBar">Loading...</div>
  <div class="boxes-wrap" id="boxesWrap"></div>
</div>

<!-- CLASSIFICATION TAB -->
<div class="tab-panel" id="tab-cls">
  <div class="class-wrap" id="classWrap"></div>
</div>

</div><!-- /app -->

<!-- MODAL -->
<div class="overlay" id="overlay" onclick="bgClose(event)">
  <div class="modal">
    <div class="mhdr"><h3 id="mTitle">Edit</h3><button class="mclose" onclick="closeModal()">&#x2715;</button></div>
    <div class="mbody" id="mBody"></div>
    <div class="mfooter" id="mFooter"></div>
  </div>
</div>

<div id="toast"></div>

<script>
